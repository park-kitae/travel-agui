GOOGLE_API_KEY=your_gemini_api_key_here
DOMAIN_PLUGIN=travel

# Optional: use Neo4j as the travel knowledge graph backend.
# Keep TRAVEL_KNOWLEDGE_BACKEND unset or set it to memory to use the in-code graph.
TRAVEL_KNOWLEDGE_BACKEND=neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=travel-agui-neo4j
NEO4J_DATABASE=neo4j
